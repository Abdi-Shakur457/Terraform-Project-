            },
            "tenancy": "default",
            "timeouts": null,
            "user_data": "#cloud-config\npackage_update: true\n\npackages:\n  - apache2\n  - php\n  - php-mysql\n  - libapache2-mod-php\n  - wget\n  - unzip\n  - mariadb-server\n  - curl\n\nruncmd:\n  # 1. Start and enable Apache\n  - systemctl start apache2\n  - systemctl enable apache2\n\n  # 2. Start and enable MariaDB\n  - systemctl start mariadb\n  - systemctl enable mariadb\n\n  # 3. Create WordPress database and user\n  - mysql -e \"CREATE DATABASE wordpress;\"\n  - mysql -e \"CREATE USER 'wpuser'@'localhost' IDENTIFIED BY 'password123';\"\n  - mysql -e \"GRANT ALL PRIVILEGES ON wordpress.* TO 'wpuser'@'localhost';\"\n  - mysql -e \"FLUSH PRIVILEGES;\"\n\n  # 4. Ensure web root exists and remove default page\n  - mkdir -p /var/www/html\n  - rm -f /var/www/html/index.html\n\n  # 5. Download and extract WordPress\n  - cd /var/www/html\n  - wget https://wordpress.org/latest.tar.gz\n  - tar -xzf latest.tar.gz\n  - mv wordpress/* .\n  - rm -rf wordpress latest.tar.gz\n\n  # 6. Configure WordPress database connection\n  - cp wp-config-sample.php wp-config.php\n  - sed -i \"s/database_name_here/wordpress/\" wp-config.php\n  - sed -i \"s/username_here/wpuser/\" wp-config.php\n  - sed -i \"s/password_here/password123/\" wp-config.php\n  - sed -i \"s/localhost/127.0.0.1/\" wp-config.php  # avoids socket issues\n\n  # 7. Set correct permissions (Ubuntu uses www-data)\n  - chown -R www-data:www-data /var/www/html\n  - chmod -R 755 /var/www/html\n\n  # 8. Restart Apache to apply changes\n  - systemctl restart apache2",
